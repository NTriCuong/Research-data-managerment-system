APP_NAME="Research Data Management System"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

SECRET_KEY=dev-secret-key-change-before-production-1234567890
ALGORITHM=HS256
CORS_ORIGINS=["http://localhost:3000"]
PASSWORD_MIN_LENGTH=8

SECRET_KEY=dev-secret-key-change-before-production-1234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE=30
REFRESH_TOKEN_EXPIRE=7
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION=15

FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql+asyncpg://postgres:<password>@localhost:5432/<database-name>

# Cloudflare R2 (S3-compatible)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
# Optional: URL public bucket/custom domain, example: https://pub-xxxx.r2.dev
CLOUDFLARE_R2_PUBLIC_BASE_URL=

TEST_DATABASE_URL=postgresql+asyncpg://postgres:<password>@localhost:5432/research_data_management_system_test

# Database backup (Super Admin)
BACKUP_DIRECTORY=backups
PG_DUMP_PATH=pg_dump
